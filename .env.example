# Primary provider: "gemini" or "openai"
PIXEL_MAGIC_PROVIDER=gemini

# Gemini API key (required if using gemini provider)
GOOGLE_API_KEY=your-gemini-api-key-here

# Gemini image model routing
PIXEL_MAGIC_GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
PIXEL_MAGIC_GEMINI_IMAGE_FALLBACK_MODEL=gemini-2.5-flash-image
PIXEL_MAGIC_GEMINI_ENABLE_IMAGE_FALLBACK=true
PIXEL_MAGIC_GEMINI_FALLBACK_TIMEOUT_S=120

# OpenAI API key (required if using openai provider)
OPENAI_API_KEY=your-openai-api-key-here

# Default settings (all optional, these are the defaults)
PIXEL_MAGIC_DIRECTION_MODE=4
PIXEL_MAGIC_IMAGE_SIZE=1K
PIXEL_MAGIC_PALETTE_SIZE=16
PIXEL_MAGIC_ALPHA_POLICY=binary
PIXEL_MAGIC_QA_VISION_ENABLED=true
PIXEL_MAGIC_QA_MAX_RETRIES=3
PIXEL_MAGIC_OUTPUT_DIR=output
