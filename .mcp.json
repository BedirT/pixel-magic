{
    "servers": {
        "pixel-magic": {
            "type": "stdio",
            "command": "uv",
            "args": [
                "--directory",
                "${workspaceFolder}",
                "run",
                "pixel-magic"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "GOOGLE_API_KEY": "${env:GOOGLE_API_KEY}",
                "OPENAI_API_KEY": "${env:OPENAI_API_KEY}",
                "PIXEL_MAGIC_OUTPUT_DIR": "${workspaceFolder}/output"
            }
        }
    }
}